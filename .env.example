# Backend environment — copy to .env and fill in. NEVER commit the real .env.

# PostgreSQL (e.g. Neon) connection string
DATABASE_URI=postgresql://user:password@host/dbname?sslmode=require

# Google Gemini API key
GEMINI_API_KEY=

# Google OAuth client ID (used to verify sign-in ID tokens)
GOOGLE_CLIENT_ID=

# Long random string used to sign session JWTs
JWT_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Frontend origin — used for CORS and the CSRF Origin check
CLIENT_URL=http://localhost:5173

# Set to "production" in prod to enable secure, cross-site cookies
NODE_ENV=development

# Optional — most hosts inject this automatically
PORT=3000
